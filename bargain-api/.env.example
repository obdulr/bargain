# Database (Railway provides this automatically)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bargainhuntrs

# API
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Add your Railway frontend URL here)
ALLOWED_ORIGINS=["http://localhost:3000","https://bargainhuntrs.com"]

# Stripe
STRIPE_API_KEY=sk_test_your_stripe_api_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key

# Railway (set automatically, but can override locally)
PORT=4030
