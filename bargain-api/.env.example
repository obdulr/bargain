# Database (Use Railway public URL for local dev or Railway provides internal URL in production)
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database

# API
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Add your Render frontend URL here)
ALLOWED_ORIGINS=["http://localhost:3030","https://bargainhuntrs.com","https://www.bargainhuntrs.com","https://bargain-mhi3.onrender.com"]

# Stripe
STRIPE_API_KEY=sk_test_your_stripe_api_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_FREE=price_your_free_price_id
STRIPE_PRICE_HUNTER=price_your_hunter_price_id
FRONTEND_URL=http://localhost:3030

# WebAuthn (passkeys)
WEB_AUTHN_RP_ID=localhost
WEB_AUTHN_RP_NAME=BargainHuntrs
WEB_AUTHN_ORIGIN=http://localhost:3030

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key

# Railway (set automatically, but can override locally)
PORT=4030
