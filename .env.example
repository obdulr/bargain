# BargainHuntrs Environment Variables Example
# Copy this file to .env.local (frontend) or .env (backend) and fill in values

# Frontend (bargain-web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4030
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Backend (bargain-api/.env)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bargainhuntrs
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=["http://localhost:3000","https://bargainhuntrs.com"]
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
RESEND_API_KEY=re_your_resend_api_key
PORT=4030
