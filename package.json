{
  "name": "bargain-huntrs",
  "version": "0.1.0",
  "private": true,
  "description": "Arbitrage intelligence platform - Find it. Flip it. Profit.",
  "workspaces": [
    "bargain-web",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^1.12.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@10.0.0"
}
